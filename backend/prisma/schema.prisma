generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects     Project[]
  aiProviders  AiProvider[]
  chatSessions ChatSession[]

  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  files    File[]
  reviews  Review[]
  chatSessions ChatSession[]
  securityScans SecurityScan[]

  @@map("projects")
}

model File {
  id        String   @id @default(uuid())
  name      String
  path      String
  content   String?  @db.Text
  mimeType  String   @map("mime_type")
  size      Int
  projectId String   @map("project_id")
  parentId  String?  @map("parent_id")
  isFolder  Boolean  @default(false) @map("is_folder")
  createdAt DateTime @default(now()) @map("created_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   File?    @relation("FileChildren", fields: [parentId], references: [id])
  children File[]   @relation("FileChildren")
  reviews  ReviewFile[]

  @@map("files")
}

model AiProvider {
  id        String   @id @default(uuid())
  name      String
  baseUrl   String   @map("base_url")
  apiKey    String?  @map("api_key")
  model     String
  isDefault Boolean  @default(false) @map("is_default")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@map("ai_providers")
}

model Review {
  id           String       @id @default(uuid())
  title        String
  reviewMode   String       @map("review_mode")
  status       ReviewStatus @default(PENDING)
  summary      String?      @db.Text
  projectId    String       @map("project_id")
  providerId   String?      @map("provider_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider  AiProvider?  @relation(fields: [providerId], references: [id])
  files     ReviewFile[]
  issues    Issue[]

  @@map("reviews")
}

model ReviewFile {
  id       String @id @default(uuid())
  reviewId String @map("review_id")
  fileId   String @map("file_id")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([reviewId, fileId])
  @@map("review_files")
}

model Issue {
  id           String   @id @default(uuid())
  reviewId     String   @map("review_id")
  title        String
  description  String   @db.Text
  severity     Severity
  category     String
  line         Int?
  filePath     String?  @map("file_path")
  recommendation String? @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("issues")
}

model ChatSession {
  id        String   @id @default(uuid())
  title     String
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("chat_sessions")
}

model Message {
  id          String      @id @default(uuid())
  sessionId   String      @map("session_id")
  role        MessageRole
  content     String      @db.Text
  createdAt   DateTime    @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Security Scan Results ──────────────────────────────────────────────────────

model SecurityScan {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  findings      Json
  scanDate      DateTime @default(now()) @map("scan_date")
  totalIssues   Int      @default(0) @map("total_issues")
  criticalCount Int      @default(0) @map("critical_count")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("security_scans")
}

// ─── Enums ──────────────────────────────────────────────────────────────────────

enum ReviewStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}
